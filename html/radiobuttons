<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0"
		/>
		<title>
			Buttondown HTML Radio Button Form Example
		</title>
	</head>
	<body>
		<div>
			<form action="https://buttondown.com/api/emails/embed-subscribe/{username}"
			method="post">
		</div>
		<fieldset>
			<div class="card">
				<h3>
					Stay informed
				</h3>
				<p>
					You'll be the first to know when we launch!
				</p>
			</div>
			<div>
				<label for="email">
					Email:
				</label>
				<input id="email" name="email" type="email" placeholder="m@example.com"
				required />
			</div>
			<div>
				<div>
					<label for="language">
						Language:
					</label>
					<input type="radio" id="english" name="english" value="english" />
					<label for="english">
						English
					</label>
					<input type="radio" id="french" name="french" value="french" />
					<label for="french">
						French
					</label>
					<input type="radio" id="spanish" name="spanish" value="spanish" />
					<label for="spanish">
						Spanish
					</label>
					<input type="radio" id="portugese" name="portugese" value="portugese"
					/>
					<label for="portugese">
						Portugese
					</label>
				</div>
				<div>
					<button type="submit">
						Subscribe
					</button>
				</div>
		</fieldset>
		</form>
		</div>
	</body>

</html>
